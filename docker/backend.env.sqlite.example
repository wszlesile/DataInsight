# ==============================
# 本地 Docker + SQLite 版示例
# 适用场景：
# 1. 本地调试镜像
# 2. 希望容器直接复用宿主机现有 SQLite 数据库
# ==============================

# ==============================
# 应用基础配置
# ==============================
PROFILE=local
DEBUG=true
SECRET_KEY=dev-secret-key

# ==============================
# 数据库配置
# 统一使用 SUPOS_DATA_INSIGHT_* 这一组变量
# 这里的 SUPOS_DATA_INSIGHT_SQLITE_PATH 必须写容器内路径
# 运行容器时再把宿主机数据库文件挂载到这个路径
# ==============================
SUPOS_DATA_INSIGHT_DBTYPE=sqlite
SUPOS_DATA_INSIGHT_SQLITE_PATH=/app/data/data_insight.db

# ==============================
# 容器内运行目录
# 这些目录建议在运行容器时挂卷
# ==============================
TEMP_DIR=/app/temp
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
LOG_LEVEL=INFO
LOG_ENABLE_FILE=true
LOG_RETENTION_DAYS=15

LLM_PROVIDER=MiniMax

# ==============================
# LLM 模型配置
# ==============================
MODEL=MiniMax-M2.7
API_KEY=replace-me
# LLM_PROVIDER=supos_llm_gateway 时使用平台注入的网关 appkey
SUPOS_DATAINSIGHT-SERVER_APPKEY=replace-me
BASE_URL=https://api.minimax.chat/v1
TEMPERATURE=0.7


SUPOS_WEB=http://192.168.19.228:8080
SUPOS_REQUEST_TIMEOUT=15
USER_CONTEXT_CACHE_TTL_SECONDS=600
UNS_MAX_EXPANDED_FILES=200
UNS_MAX_EXPAND_DEPTH=5
UNS_TREE_PAGE_SIZE=100
UNS_DETAIL_WORKERS=5
UNS_IMPORT_MAX_CONCURRENT=2

# ==============================
# Gunicorn 配置
# ==============================
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=600
