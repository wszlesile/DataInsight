# ==============================
# 本地 Docker + SQLite 版示例
# 适用场景：
# 1. 本地调试镜像
# 2. 希望容器直接复用宿主机现有 SQLite 数据库
# ==============================

# ==============================
# 应用基础配置
# ==============================
PROFILE=local
DEBUG=true
SECRET_KEY=dev-secret-key

# ==============================
# 数据库配置
# 这里的 SQLITE_PATH 必须写容器内路径
# 运行容器时再把宿主机数据库文件挂载到这个路径
# ==============================
DB_TYPE=sqlite
SQLITE_PATH=/app/data/data_insight.db

# ==============================
# 容器内运行目录
# 这些目录建议在运行容器时挂卷
# ==============================
TEMP_DIR=/app/temp
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
LOG_LEVEL=INFO
LOG_ENABLE_FILE=true
LOG_RETENTION_DAYS=15

LLM_MODEL_ACTIVE=MiniMax

# ==============================
# MiniMax-M2.5 模型配置
# ==============================
MINIMAX_M2_5_MODEL=MiniMax-M2.7
MINIMAX_M2_5_API_KEY=sk-cp-SFsWXvE70P9ZkxP9hYaCwl75PJmfPnrQs0AEmCkyoXwoXNznUEONG-XT0I8TGk0XiKKHKgxQJJtfP_0JI9qCoXiCOLbujb15wlkVdmBfrcJbhsvWWW5iwwU
MINIMAX_M2_5_BASE_URL=https://api.minimax.chat/v1

# ==============================
# Qwen3-80B 模型配置
# ==============================
QWEN3_80B_MODEL=Qwen3-80B
QWEN3_80B_API_KEY=EMPTY
QWEN3_80B_BASE_URL=http://192.168.8.206:5103/v1


SUPOS_WEB=http://192.168.19.228:8080
SUPOS_REQUEST_TIMEOUT=15
USER_CONTEXT_CACHE_TTL_SECONDS=600
UNS_MAX_EXPANDED_FILES=200
UNS_MAX_EXPAND_DEPTH=5
UNS_TREE_PAGE_SIZE=100
UNS_DETAIL_WORKERS=5
UNS_IMPORT_MAX_CONCURRENT=2

# ==============================
# Gunicorn 配置
# ==============================
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=600
