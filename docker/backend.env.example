# ==============================
# 外置数据库版示例
# 适用场景：
# 1. 测试环境
# 2. 生产环境
# 3. 本地 Docker 联调，但数据库不使用 SQLite
# ==============================

# ==============================
# 应用基础配置
# ==============================
PROFILE=prod
DEBUG=false
SECRET_KEY=replace-me

# ==============================
# 容器内运行目录
# 这些目录建议在运行容器时挂卷
# ==============================
TEMP_DIR=/app/temp
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
LOG_LEVEL=INFO
LOG_ENABLE_FILE=true
LOG_RETENTION_DAYS=15

# ==============================
# 数据库配置
# 数据库统一使用 SUPOS_DATA_INSIGHT_* 这一组变量。
# DB_TYPE 支持：mysql / postgres / postgresql
# ==============================
SUPOS_DATA_INSIGHT_DBTYPE=postgresql
SUPOS_DATA_INSIGHT_HOST=127.0.0.1
SUPOS_DATA_INSIGHT_PORT=5432
SUPOS_DATA_INSIGHT_DBNAME=data_insight
SUPOS_DATA_INSIGHT_USERNAME=postgres
SUPOS_DATA_INSIGHT_PASSWORD=replace-me

# ==============================
# 大模型配置
# 按当前实际使用的模型填写
# ==============================
LLM_PROVIDER=MiniMax
MODEL=MiniMax-M2.7
API_KEY=replace-me
# LLM_PROVIDER=supos_llm_gateway 时使用平台注入的网关 appkey
SUPOS_DATAINSIGHT-SERVER_APPKEY=replace-me
BASE_URL=https://api.minimax.chat/v1
TEMPERATURE=0.7

# ==============================
# SUPOS / 用户上下文配置
# ==============================
SUPOS_WEB=http://127.0.0.1:8080
SUPOS_REQUEST_TIMEOUT=15
USER_CONTEXT_CACHE_TTL_SECONDS=600
UNS_MAX_EXPANDED_FILES=200
UNS_MAX_EXPAND_DEPTH=5
UNS_TREE_PAGE_SIZE=100
UNS_DETAIL_WORKERS=5
UNS_IMPORT_MAX_CONCURRENT=2

# ==============================
# Gunicorn 配置
# WEB_CONCURRENCY：worker 数量
# GUNICORN_THREADS：每个 worker 的线程数
# GUNICORN_TIMEOUT：单次请求超时时间（秒）
# ==============================
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=600
